{
  "name": "japan-seasons-mcp",
  "version": "0.4.18",
  "mcpName": "io.github.haomingkoo/japan-seasons",
  "description": "Year-round Japan seasonal travel — cherry blossom, autumn leaves, fruit picking, flowers & more. 1,700+ spots with live data. MCP server powered by Japan Meteorological Corporation.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "japan-seasons-mcp": "dist/index.js",
    "japan-sakura-koyo-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "node --watch --enable-source-maps src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "vitest",
    "version": "node scripts/sync-version.mjs && git add server.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "japan",
    "japan-travel",
    "seasons",
    "seasonal",
    "seasonal-activities",
    "sakura",
    "cherry-blossom",
    "koyo",
    "autumn-leaves",
    "forecast",
    "travel",
    "jma",
    "bloom",
    "hanami",
    "momiji",
    "kawazu",
    "wisteria",
    "hydrangea",
    "fruit-picking",
    "flowers",
    "festivals",
    "fireworks",
    "matsuri",
    "weather",
    "cherry-blossom-forecast",
    "autumn-leaves-forecast"
  ],
  "author": "Haoming Koo",
  "homepage": "https://github.com/haomingkoo/japan-seasons-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/haomingkoo/japan-seasons-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/haomingkoo/japan-seasons-mcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE",
    "server.json",
    "smithery.yaml",
    "smithery.remote-config.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
